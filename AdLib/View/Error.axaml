<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModel="clr-namespace:AdLib.ViewModel"
             x:DataType="viewModel:ErrorViewModel"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
             x:Class="AdLib.View.Error">
    
    <Design.DataContext>
        <viewModel:ErrorViewModel />
    </Design.DataContext>
    
    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
        <TextBlock HorizontalAlignment="Center" Classes="h1">Error</TextBlock>
        <TextBlock HorizontalAlignment="Center">An error occurred!</TextBlock>
        <Separator />
        <TextBlock HorizontalAlignment="Center" FontWeight="Bold">Details:</TextBlock>
        <TextBlock HorizontalAlignment="Center" Text="{Binding Message}" />
    </StackPanel>
</UserControl>
