<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModel="clr-namespace:AdLib.ViewModel"
             xmlns:modal="clr-namespace:AdLib.ViewModel.Modal"
             x:DataType="modal:NoModalViewModel"
             x:Class="AdLib.View.Modal.NoModal">
